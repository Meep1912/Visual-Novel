def readlines(lines, line):
    words = lines[line].strip().split()
    global hasBG, NextBG, character1, character2
    to_remove = set()
    
    for i, word in enumerate(words):
        if word == "BG":
            hasBG = True
            NextBG = backgrounds[words[i + 1]]
            to_remove.add(i)
            to_remove.add(i + 1)
        elif word == "CH1":
            character1 = characters[words[i + 1]]
            to_remove.add(i)
            to_remove.add(i + 1)
        elif word == "CH2":
            character2 = characters[words[i + 1]]
            to_remove.add(i)
            to_remove.add(i + 1)
    
    words = [w for i, w in enumerate(words) if i not in to_remove]
    return " ".join(words)


