def fade(NextBG, currentBG):
    old = pygame.image.load(currentBG).convert_alpha()
    new = pygame.image.load(NextBG).convert_alpha()
    for alpha in range(0, 256):
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                sys.exit()
            elif event.type == pygame.KEYDOWN:
                return
        screen.fill((0, 0, 0))
        temp_old = old.copy()
        temp_old.fill((255, 255, 255, 255 - alpha), special_flags=pygame.BLEND_RGBA_MULT)
        screen.blit(temp_old, (0, 0))
        temp_new = new.copy()
        temp_new.fill((255, 255, 255, alpha), special_flags=pygame.BLEND_RGBA_MULT)
        screen.blit(temp_new, (0, 0))
        pygame.display.flip()
        pygame.time.delay(4)

class Slider:
    def __init__(self, x, y, w, name):
        self.track = pygame.Rect(x, y, w, 6)
        self.handle = pygame.Rect(x, y - 6, 10, 18)
        self.name = name
        self.value = 0
        self.dragging = False

    def draw(self, screen, font):
        pygame.draw.rect(screen, (60, 60, 60), self.track)
        pygame.draw.rect(screen, (200, 200, 200), self.handle)
        label = font.render(self.name, False, (150, 150, 150))
        screen.blit(label, (self.track.x, self.track.y - 30))

    def handle_event(self, event):
        if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
            if self.handle.collidepoint(event.pos):
                self.dragging = True
        elif event.type == pygame.MOUSEBUTTONUP:
            self.dragging = False
        elif event.type == pygame.MOUSEMOTION:
            if self.dragging:
                x = event.pos[0]
                x = max(self.track.left, min(x, self.track.right))
                self.handle.centerx = x
                self.value = (x - self.track.left) / self.track.width

    def get(self, min_val, max_val):
        return int((self.value) * (max_val - min_val)) + min_val

def save(line_index1):
    save_file = open("Assets/save_file.txt","w")
    line_index1 = str(line_index1)
    line = line_index1.split()[0]
    global savestate
    save_file.write(line)
    savestate = "saved"
    save_file.close()

def load():
    save_file = open("Assets/save_file.txt","r")
    line = save_file.readline()
    line_index = int(line)
    global loadstate
    loadstate = "loaded"
    return line_index



